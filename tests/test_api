
import json


class TestRotaIndex:

    def test_pagina_inicial(self, client):
        resposta = client.get("/")
        assert resposta.status_code == 200

    def test_pag_inicial(self, client):
        resposta = client.get("/")
        assert b"GeekStore" in resposta.data or resposta.status_code == 200


class TestRotaProdutos:

    def test_listar_produtos(self, client):
        resposta = client.get("/produtos")
        assert resposta.status_code == 200

    def test_listar_produtos_json(self, client):
        resposta = client.get("/produtos")
        assert resposta.content_type == "application/json"

    def test_listar_produtos_lista(self, client):
        resposta = client.get("/produtos")
        dados = json.loads(resposta.data)
        assert isinstance(dados, list)
        assert len(dados) == 4

    def test_produtos_chaves(self, client):
        resposta = client.get("/produtos")
        dados = json.loads(resposta.data)
        for produto in dados:
            assert "id"      in produto
            assert "nome"    in produto
            assert "preco"   in produto
            assert "estoque" in produto

    def test_buscar_produto_existente(self, client):
        resposta = client.get("/produtos/1")
        assert resposta.status_code == 200

    def test_buscar_produto_existente_dados(self, client):
        resposta = client.get("/produtos/1")
        dados = json.loads(resposta.data)
        assert dados["id"]    == 1
        assert "Lego"         in dados["nome"]
        assert dados["preco"] == 480.00

    def test_buscar_produto_inexistente(self, client):
        resposta = client.get("/produtos/9999")
        assert resposta.status_code == 404

    def test_erro_buscar_produto_inexistente(self, client):
        resposta = client.get("/produtos/9999")
        dados = json.loads(resposta.data)
        assert "erro" in dados


class TestRotaComprar:

    def _payload(self, produto_id=3, quantidade=1, cupom=None):
        payload = {
            "produto_id": produto_id,
            "quantidade": quantidade,
            "dados_pagamento": {"numero": "4189678"}
        }
        if cupom:
            payload["cupom"] = cupom
        return payload

    def test_compra_valida(self, client):
        resposta = client.post(
            "/comprar",
            data=json.dumps(self._payload()),
            content_type="application/json"
        )
        assert resposta.status_code == 200

    def test_compra_valida_ok(self, client):
        resposta = client.post(
            "/comprar",
            data=json.dumps(self._payload()),
            content_type="application/json"
        )
        dados = json.loads(resposta.data)
        assert dados["sucesso"] is True
        assert "pedido_id"   in dados
        assert "valor_total" in dados
        assert "nsu"         in dados

    def test_compra_cupom_valido(self, client):
        resposta = client.post(
            "/comprar",
            data=json.dumps(self._payload(cupom="DESCONTO10")),
            content_type="application/json"
        )
        dados = json.loads(resposta.data)
        assert dados["sucesso"] is True
        # 10% off em R$36,89 = R$33,20
        assert dados["valor_total"] == pytest.approx(33.20, rel=1e-2)

    def test_compra_sem_estoque(self, client):
        """Produto id=2 (Cartucho) tem estoque=0 → deve retornar 400."""
        resposta = client.post(
            "/comprar",
            data=json.dumps(self._payload(produto_id=2)),
            content_type="application/json"
        )
        assert resposta.status_code == 400

    def test_compra_produto_inexistente(self, client):
        resposta = client.post(
            "/comprar",
            data=json.dumps(self._payload(produto_id=9999)),
            content_type="application/json"
        )
        assert resposta.status_code == 404

    def test_compra_cupom_invalido(self, client):
        resposta = client.post(
            "/comprar",
            data=json.dumps(self._payload(cupom="CUPOM_ERRADO")),
            content_type="application/json"
        )
        assert resposta.status_code == 400
        dados = json.loads(resposta.data)
        assert dados["sucesso"] is False


import pytest